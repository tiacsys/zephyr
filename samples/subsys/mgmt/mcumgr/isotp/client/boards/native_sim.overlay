 *
 * Route the MCUmgr ISO-TP transport to the native Linux SocketCAN driver so
 * that the client and server samples (two separate native_sim processes) can
 * talk to each other over a shared host CAN interface (e.g. vcan0).
 *
 * Adjust "host-interface" to match the interface you created on the host.
 */

/ {
	chosen {
		zephyr,canbus = &can0;
	};

	/* littlefs auto-mounted at /lfs; firmware images and files to push to nodes
	 * are sourced from here (stage them with the built-in "fs" shell commands).
	 */
	fstab {
		compatible = "zephyr,fstab";
		lfs1: lfs1 {
			compatible = "zephyr,fstab,littlefs";
			mount-point = "/lfs";
			partition = <&storage_partition>;
			automount;
			read-size = <16>;
			prog-size = <16>;
			cache-size = <64>;
			lookahead-size = <32>;
			block-cycles = <512>;
		};
	};
};

&can0 {
	status = "okay";
	host-interface = "vcan0";
};

&can_loopback0 {
	status = "disabled";
};
