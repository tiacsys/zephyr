# The Kconfig file is dedicated to smp_client subdirectory of MCUmgr
# subsystem and provides Kconfig options to control aspects of
# Simple Management Protocol Client (SMP) processing source code provided
# under the subdirectory.

config SMP_CLIENT
	bool "SMP Client support"
	help
	  This will enable SMP Request generation and response handling.

if SMP_CLIENT || ZTEST

config SMP_CMD_DEFAULT_LIFE_TIME
	int "SMP command lifetime in seconds"
	range 2 30
	default 5
	help
	  This define lifetime for SMP client send request. This configure is used if a request
	  with a timeout of 0 is used.

config SMP_CMD_RETRY_TIME
	int "SMP command re-send period in ms"
	range 100 1000
	default 500
	help
	  The time (in ms) which the SMP client will wait for a response before re-sending a
	  command.

config SMP_CLIENT_CMD_MAX
	int "SMP client max buffer count"
	default 4
	help
	  Define how many active requests that the client can handle

config MCUMGR_SMP_CLIENT_SHELL
	bool "MCUmgr SMP client shell (smpc)"
	depends on SHELL
	select MCUMGR_GRP_OS_CLIENT
	select MCUMGR_GRP_OS_CLIENT_ECHO
	select MCUMGR_GRP_OS_CLIENT_RESET
	help
	  Enables the interactive "smpc" shell that drives MCUmgr management
	  operations over a registered SMP client transport, e.g. to perform
	  firmware updates on remote nodes.

	  The base shell provides connectivity and OS commands only ("smpc echo",
	  "smpc reset", "smpc transport"); image and file management commands are
	  enabled separately below, so that e.g. an echo connectivity test does
	  not pull in the file system or image management stacks.

	  Transports are taken from the SMP client transport registry; with more
	  than one transport enabled, select one at runtime with
	  "smpc transport <name>". Transport backends (such as
	  MCUMGR_SMP_CLIENT_SHELL_ISOTP) add transport-specific subcommands.

if MCUMGR_SMP_CLIENT_SHELL

config MCUMGR_SMP_CLIENT_SHELL_IMG
	bool "Image management commands (smpc image ...)"
	default y
	select MCUMGR_GRP_IMG_CLIENT
	select MCUBOOT_BOOTUTIL_LIB
	help
	  Enables "smpc image list/test/confirm/erase" for inspecting and marking
	  firmware images on the target. Protocol-only: needs the image management
	  client and the MCUboot bootutil library (for image structures), but no
	  local flash or file system.

config MCUMGR_SMP_CLIENT_SHELL_IMG_UPLOAD
	bool "Image upload and upgrade commands (smpc image upload, smpc upgrade)"
	default y
	depends on MCUMGR_SMP_CLIENT_SHELL_IMG
	depends on FILE_SYSTEM
	help
	  Enables "smpc image upload <file> [slot]" and the one-step
	  "smpc upgrade <file> [test|confirm]" command. The firmware image is
	  read from a mounted local file system.

config MCUMGR_SMP_CLIENT_SHELL_FILE
	bool "File transfer commands (smpc file ...)"
	default y
	depends on FILE_SYSTEM
	help
	  Enables "smpc file upload/download" for copying files between a mounted
	  local file system and the target (MCUmgr FS management group).

endif # MCUMGR_SMP_CLIENT_SHELL

module = MCUMGR_SMP_CLIENT
module-str = mcumgr_smp_client
source "subsys/logging/Kconfig.template.log_config"

endif # SMP_CLIENT
