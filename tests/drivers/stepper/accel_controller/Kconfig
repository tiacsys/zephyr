mainmenu "Accel Controller Test"

source "Kconfig.zephyr"

config STEPPER_CTRL_TEST_STEPPING_TOLERANCE
	int "Stepper step tolerance percentage"
	default 7
	help
	  Additional margin (%) added or subtracted to expected steps for run
	  commands to account for timing inaccuracys and runtime.

config STEPPER_CTRL_TEST_TIMEOUT_TOLERANCE_MS
	int "Stepper timeout tolerance in ms"
	default 100
	help
	  Additional wait time for positioning and stop commands.
